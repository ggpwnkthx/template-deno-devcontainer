{
  "imports": {
    "@/": "./"
  },
  "exclude": [
    ".opencode"
  ],
  "tasks": {
    "test": "deno test -A",
    "lint": "deno lint",
    "fmt": "deno fmt",
    "check": "deno check"
  },
  "lint": {
    "rules": {
      "tags": ["recommended"]
    }
  },
  "fmt": {
    "useTabs": false,
    "indentWidth": 2,
    "singleQuote": true,
    "proseWrap": "preserve"
  }
}
