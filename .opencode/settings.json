{
  "$schema": "https://opencode.ai/config.json",
  "provider": {
    "minimax": {
      "npm": "@ai-sdk/anthropic",
      "options": {
        "baseURL": "https://api.minimax.io/anthropic/v1",
        "apiKey": "{env:MINIMAX_API_KEY}"
      },
      "models": {
        "MiniMax-M2.7": {
          "name": "MiniMax-M2.7"
        }
      }
    }
  },
  "model": "minimax/MiniMax-M2.7",
  "formatter": {
    "deno-fmt": {
      "command": ["deno", "fmt", "$FILE"],
      "extensions": [".ts", ".tsx"]
    }
  }
}
